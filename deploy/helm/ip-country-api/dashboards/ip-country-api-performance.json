        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ip_country_http_request_duration_seconds_bucket{namespace=~\"${namespace:regex}\",route=~\"${route:regex}\"}[5m]))) and on() (sum(increase(ip_country_http_request_duration_seconds_count{namespace=~\"${namespace:regex}\",route=~\"${route:regex}\"}[5m])) > 0)",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ip_country_http_request_duration_seconds_bucket{namespace=~\"${namespace:regex}\",route=~\"${route:regex}\"}[5m]))) and on() (sum(increase(ip_country_http_request_duration_seconds_count{namespace=~\"${namespace:regex}\",route=~\"${route:regex}\"}[5m])) > 0)",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(ip_country_http_request_duration_seconds_bucket{namespace=~\"${namespace:regex}\",route=~\"${route:regex}\"}[5m]))) and on() (sum(increase(ip_country_http_request_duration_seconds_count{namespace=~\"${namespace:regex}\",route=~\"${route:regex}\"}[5m])) > 0)",
          "legendFormat": "p99",
          "refId": "C"
        }
