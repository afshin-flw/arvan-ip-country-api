APP_NAME=IP Country API
APP_ENV=development
APP_VERSION=0.1.0
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json
DATABASE_URL=
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT_SECONDS=5
DATABASE_CONNECT_TIMEOUT_SECONDS=5
GEOIP_PROVIDER=ipinfo
GEOIP_PROVIDER_BASE_URL=https://api.ipinfo.io
IPINFO_TOKEN=
GEOIP_PROVIDER_TIMEOUT_SECONDS=3
GEOIP_PROVIDER_MAX_RETRIES=2
GEOIP_CACHE_TTL_SECONDS=2592000
METRICS_ENABLED=true
CORS_ALLOWED_ORIGINS=[]
TRUSTED_HOSTS=["localhost","127.0.0.1"]
